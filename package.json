{
  "name": "sortie-docs",
  "description": "Documentation for Sortie - AI coding agent orchestrator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sortie-ai/docs.git"
  },
  "private": true,
  "scripts": {
    "unshallow": "git fetch --unshallow || true",
    "prebuild": "npm run unshallow",
    "build": "hugo --environment production --gc --logLevel info --minify --cleanDestinationDir --printPathWarnings --printMemoryUsage",
    "server": "hugo server --environment development --logLevel info --buildDrafts --buildFuture --ignoreCache --disableFastRender"
  },
  "devDependencies": {
    "wrangler": "^4.77.0"
  }
}
